{
  "$schema": "https://raw.githubusercontent.com/nickkuk/nickkuk.github.io/main/tauri.schema.json",
  "productName": "FormAssist",
  "version": "0.3.14",
  "identifier": "com.formassist.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FormAssist",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": "^.+"
    },
    "sql": {
      "preload": ["sqlite:formassist.db"]
    },
    "updater": {
      "active": true,
      "dialog": false,
      "endpoints": [
        "https://github.com/yosniper973-ux/formassist/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBQzA5Q0JGQjc1MUZDRDkKUldUWi9GRzN2NXpBcW80VDdDT0Y2cHZhMUt3WnZHT0tCZmhNWG02QzdGaXovZW5MTG56SnRKc2kK"
    }
  }
}
