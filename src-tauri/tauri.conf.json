{
  "$schema": "https://raw.githubusercontent.com/nickkuk/nickkuk.github.io/main/tauri.schema.json",
  "productName": "FormAssist",
  "version": "0.1.0",
  "identifier": "com.formassist.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FormAssist",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.anthropic.com; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "fr-FR"
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": {
        "db": "sqlite:formassist.db"
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/yosniper973-ux/formassist/releases/latest/download/latest.json"
      ],
      "dialog": false,
      "pubkey": ""
    }
  }
}
